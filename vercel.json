{
  "version": 2,
  "builds": [
    {
      "src": "Guest-Website/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "Guest-Website/dist"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/Guest-Website/$1"
    }
  ]
}